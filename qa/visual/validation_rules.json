{
  "rules": [
    {
      "name": "hero_page",
      "path_regex": "^qa/visual/netcorner/nuxt/pl/hero_page/.*\\.json$",
      "scenario_id_regex": "^vrt-netcorner-nuxt-pl-hero-[a-z0-9-]+$",
      "target_url_regex": "^/.*$"
    },
    {
      "name": "layers",
      "path_regex": "^qa/visual/netcorner/nuxt/pl/layers/.*\\.json$",
      "scenario_id_regex": "^vrt-netcorner-nuxt-pl-layers-[a-z0-9-]+$",
      "target_url_regex": "^/.*$"
    },
    {
      "name": "product_page",
      "path_regex": "^qa/visual/netcorner/nuxt/pl/product_page/.*\\.json$",
      "scenario_id_regex": "^vrt-netcorner-nuxt-pl-product-([0-9]+)$",
      "target_url_regex": "^/product/([0-9]+)$",
      "match_first_capture_group": true
    },
    {
      "name": "category_page",
      "path_regex": "^qa/visual/netcorner/nuxt/pl/category_page/.*\\.json$",
      "scenario_id_regex": "^vrt-netcorner-nuxt-pl-category-([0-9]+)$",
      "target_url_regex": "^/category/([0-9]+)(?:/.*|,.*|\\.html)?$",
      "match_first_capture_group": true
    },
    {
      "name": "producer_page",
      "path_regex": "^qa/visual/netcorner/nuxt/pl/producer_page/.*\\.json$",
      "scenario_id_regex": "^vrt-netcorner-nuxt-pl-producer-([0-9]+)$",
      "target_url_regex": "^/producer/([0-9]+)(?:/.*|\\.html)?$",
      "match_first_capture_group": true
    }
  ]
}

[
  {
    "id": "vrt-netcorner-nuxt-pl-hero-homepage-full_page",
    "name": "Homepage main visual",
    "suite_id": "netcorner/nuxt/pl/hero_page",
    "target_url": "/",
    "compare_mode": "hybrid",
    "viewport": ["fhd", "tablet", "mobile"],
    "capture": {
      "type": "page",
      "full_page": true
    },
    "mask": {
      "selectors": [
        "[data-name='heroSlider']",
        "[data-name='dailyDeal']",
        "[data-name='TimeCounterDays']",
        "[data-name='TimeCounterHours']",
        "[data-name='TimeCounterMinutes']",
        "[data-name='TimeCounterSeconds']",
        ".cookie-banner",
        "[data-testid='dynamic-banner']"
      ]
    },
    "thresholds": {
      "pixel_max": 0.01,
      "lpips_max": 0.12,
      "dists_max": 0.12
    }
  },

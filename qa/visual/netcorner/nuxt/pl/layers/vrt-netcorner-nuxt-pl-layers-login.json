{
  "id": "vrt-netcorner-nuxt-pl-layers-login",
  "name": "Login page visual",
  "suite_id": "netcorner/nuxt/pl/layers",
  "target_url": "/",
  "compare_mode": "hybrid",
  "capture": {
      "type": "element",
      "locator": "[data-name='dialogContent']"
  },
  "thresholds": {
    "pixel_max": 0.01,
    "lpips_max": 0.12,
    "dists_max": 0.12
  },
  "steps": [
    {
      "action": "click",
      "selector": "[data-name='loginDialogTrigger']"
    },
    {
      "action": "wait_for_selector",
      "selector": "[data-name='loginForm']:visible",
      "timeout_ms": 5000
    }
  ]
}

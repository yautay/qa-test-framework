# Recommended CI/CD overrides. Defaults live in `settings.py` and `settings_cli.py`, so set these only when you need to change behavior.

# Browser/runtime settings
BROWSER=chromium
IS_GRID_AVAILABLE=0
GRID_WS_ENDPOINT=ws://127.0.0.1:9323/
GRID_CONNECT_TIMEOUT_MS=30000
HEADLESS=1
IGNORE_HTTPS_ERRORS=1

# Environment targets
BASE_URL=
BASE_URL_OVERRIDE=
REFERENCE_HOST=

# Artifacts & diagnostics
ARTIFACTS_DIR=artifacts
RECORD_VIDEO=1
VIDEO_MIN_SECONDS=30
HIGHLIGHT_ON_FAIL=1

# Pytest discovery guard
MIN_EXPECTED_TESTS=1
PYTEST_COLLECT_TIMEOUT_SECONDS=120

# Logging (Loguru)
CONSOLE_LOG_LEVEL=WARNING
LOG_ROTATION=50 MB
LOG_RETENTION=7 days
LOG_COMPRESSION=zip

# Reporting API
REPORTING_ENABLED=1
REPORTING_SCHEMA_VERSION=2.0
REPORTING_SOURCE_PROJECT=netQArner
REPORTING_SOURCE_ORIGIN=
FRAMEWORK_VERSION=1.0.0
REPORTING_API_URL=http://127.0.0.1:58473
REPORTING_API_TOKEN=
REPORTING_API_RUN_START_ENDPOINT=/test-run/start
REPORTING_API_TEST_RESULT_ENDPOINT=/test-run/test-result
REPORTING_API_RUN_FINISH_ENDPOINT=/test-run/finish
REPORTING_API_BUG_ENDPOINT=/test-run/bug-report
REPORTING_API_ASO_ENDPOINT=/test-run/aso-report
REPORTING_API_TIMEOUT_SECONDS=5
REPORTING_API_RETRIES=2

# Local test API helper (tools/reporting/test_api.py)
TEST_API_PORT=58473

# Visual regression
VISUAL_ENABLED=1
VISUAL_COMPARE_MODE=pixel
VISUAL_BASELINE_PROVIDER=local
VISUAL_BASELINE_PROFILE=test-ref
VISUAL_BASELINE_VERSION=latest
VISUAL_CACHE_DIR=.visual_cache
VISUAL_FAIL_ON_MISSING_BASELINE=0
VISUAL_WARN_AS_FAIL=0

# Visual baseline MinIO
VISUAL_MINIO_ENDPOINT=127.0.0.1:9000
VISUAL_MINIO_ACCESS_KEY=minioadmin
VISUAL_MINIO_SECRET_KEY=minioadmin
VISUAL_MINIO_BUCKET=visual-baselines
VISUAL_MINIO_SECURE=0

# Visual perceptual API (LPIPS + DISTS)
VISUAL_PERCEPTUAL_ENABLED=0
VISUAL_PERCEPTUAL_REQUIRED=0
VISUAL_PERCEPTUAL_API_URL=
VISUAL_PERCEPTUAL_TIMEOUT_SECONDS=15
VISUAL_PERCEPTUAL_HEALTH_TIMEOUT_SECONDS=2
VISUAL_PERCEPTUAL_RETRIES=2
VISUAL_PERCEPTUAL_FAIL_FAST_ERRORS=3
VISUAL_PERCEPTUAL_FALLBACK_MODE=pixel
VISUAL_PERCEPTUAL_FORCE_DEVICE=
VISUAL_PERCEPTUAL_MAX_SIDE=1024
VISUAL_PERCEPTUAL_OVERLAY_ON=test
VISUAL_PERCEPTUAL_ALPHA=0.45
VISUAL_PERCEPTUAL_LPIPS_NET=alex

# Visual uncertain zone
VISUAL_UNCERTAIN_ENABLED=1
VISUAL_UNCERTAIN_PIXEL_DELTA=0.001
VISUAL_UNCERTAIN_LPIPS_DELTA=0.01
VISUAL_UNCERTAIN_DISTS_DELTA=0.01

# Optional smoke credentials for legacy flows
SMOKE_LOGIN=
SMOKE_PASSWORD=

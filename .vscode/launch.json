{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Pytest: Debug Test (breakpoint-friendly)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "subProcess": true,
            "purpose": [
                "debug-test"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTEST_ADDOPTS": "-q -s --maxfail=1",
                "HEADLESS": "0",
                "PWDEBUG": "1",
                "BROWSER": "chromium",
                "IS_GRID_AVAILABLE": "0",
                "REPORTING_ENABLED": "0",
                "ALLURE_ENABLED": "0",
                "PYTEST_HTML_ENABLED": "0",
                "RECORD_VIDEO": "0",
                "VISUAL_ENABLED": "0",
                "PMS_ENABLED": "0"
            }
        },
        {
            "name": "Pytest: Debug Test (framework step-in)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "subProcess": true,
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTEST_ADDOPTS": "-q -s --maxfail=1",
                "HEADLESS": "0",
                "PWDEBUG": "1",
                "BROWSER": "chromium",
                "IS_GRID_AVAILABLE": "0",
                "REPORTING_ENABLED": "0",
                "ALLURE_ENABLED": "0",
                "PYTEST_HTML_ENABLED": "0",
                "RECORD_VIDEO": "0",
                "VISUAL_ENABLED": "0",
                "PMS_ENABLED": "0"
            }
        },
        {
            "name": "Pytest: Debug Netcorner E2E (current file)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "module": "pytest",
            "subProcess": true,
            "args": [
                "${file}",
                "-q",
                "-s",
                "--maxfail=1"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "HEADLESS": "0",
                "PWDEBUG": "1",
                "BROWSER": "chromium",
                "IS_GRID_AVAILABLE": "0",
                "REPORTING_ENABLED": "0",
                "ALLURE_ENABLED": "0",
                "PYTEST_HTML_ENABLED": "0",
                "RECORD_VIDEO": "0",
                "VISUAL_ENABLED": "0",
                "PMS_ENABLED": "0"
            }
        },
        {
            "name": "Pytest: Debug Netcorner E2E (nuxt/pl suite)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "module": "pytest",
            "subProcess": true,
            "args": [
                "qa/e2e/netcorner/nuxt/pl/tests",
                "-q",
                "-s",
                "--maxfail=1"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "HEADLESS": "0",
                "PWDEBUG": "1",
                "BROWSER": "chromium",
                "IS_GRID_AVAILABLE": "0",
                "REPORTING_ENABLED": "0",
                "ALLURE_ENABLED": "0",
                "PYTEST_HTML_ENABLED": "0",
                "RECORD_VIDEO": "0",
                "VISUAL_ENABLED": "0",
                "PMS_ENABLED": "0"
            }
        }
    ]
}

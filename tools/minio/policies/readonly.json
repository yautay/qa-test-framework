{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListVisualBaselinesBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::__MINIO_BUCKET__"
      ]
    },
    {
      "Sid": "ReadVisualBaselineObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::__MINIO_BUCKET__/*"
      ]
    }
  ]
}

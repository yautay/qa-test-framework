# MinIO root account (used by minio + minio-init)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Bucket created during init
MINIO_BUCKET=visual-baselines
MINIO_BUCKET_QUOTA=20GiB

# Readonly account created during init
VISUAL_READONLY_USER=visual-readonly
VISUAL_READONLY_PASSWORD=readonly-pass-change-me

# Release account created during init
VISUAL_RELEASE_USER=visual-release
VISUAL_RELEASE_PASSWORD=release-pass-change-me
